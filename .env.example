# ─────────────────────────────────────────────────────────────────
# Strikewise — Environment Variables
# Copy this file to .env.local for local development.
# Set these in Railway → your service → Variables.
# NEVER commit .env or .env.local to git.
# ─────────────────────────────────────────────────────────────────

# ── Lightning data provider ──────────────────────────────────────
# Options: "mock" | "noaa-glm" | "custom"
VITE_LIGHTNING_PROVIDER=mock

# ── NOAA GOES GLM (no key needed — public bucket) ────────────────
VITE_NOAA_GLM_BUCKET=noaa-goes18
VITE_NOAA_GLM_BASE_URL=https://noaa-goes18.s3.amazonaws.com
VITE_NOAA_GLM_PRODUCT=GLM-L2-LCFA
VITE_NOAA_GLM_POLL_SECONDS=15

# ── Custom / commercial provider (future) ────────────────────────
# VITE_LIGHTNING_API_URL=https://api.yourprovider.com/v1
# VITE_LIGHTNING_API_KEY=your_key_here

# ── App config ────────────────────────────────────────────────────
VITE_APP_NAME=Strikewise
VITE_APP_ENV=development
