# Strikewise backend
NODE_ENV=development
PORT=3000
LIGHTNING_PROVIDER=mock
CORS_ORIGIN=*

# xWeather commercial provider
# LIGHTNING_PROVIDER=xweather
# XWEATHER_CLIENT_ID=your_client_id
# XWEATHER_CLIENT_SECRET=your_client_secret

# NOAA GOES GLM public bucket config
NOAA_GLM_BUCKET=noaa-goes18
NOAA_GLM_BASE_URL=https://noaa-goes18.s3.amazonaws.com
NOAA_GLM_PRODUCT=GLM-L2-LCFA
NOAA_GLM_POLL_SECONDS=15
